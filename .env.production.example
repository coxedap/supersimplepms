# ── Database ──────────────────────────────────────────────────────────────────
# Provided automatically when you add a Railway PostgreSQL service.
# Copy the value from the PostgreSQL service's "Variables" tab.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/execution_os?schema=public

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production

# Railway injects PORT automatically — do not set this manually.
# PORT=

# The public URL of your Railway app (shown in Railway dashboard after deploy).
APP_URL=https://your-app.up.railway.app

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret, e.g.:  openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-secret

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → Create API Key
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key_here

# Must be a verified sender address/domain in your Resend account.
# For testing without a domain, use: onboarding@resend.dev (Resend's shared domain).
SMTP_FROM=noreply@yourdomain.com
