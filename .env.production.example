# ── Database (Supabase) ───────────────────────────────────────────────────────
# Project Settings → Database → Connection String → URI
# Use the "Session mode" pooler URL (port 5432) for persistent Node.js connections
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production

# Railway injects PORT automatically — do not set this manually.
# PORT=

# Your Vercel frontend URL — used to build invite email links (set after Vercel deploy)
APP_URL=https://your-app.vercel.app

# Same as APP_URL — used for CORS to allow the frontend to call the backend
FRONTEND_URL=https://your-app.vercel.app

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-secret

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → Create API Key
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key_here

# Use onboarding@resend.dev until you verify a custom domain in Resend
SMTP_FROM=onboarding@resend.dev
